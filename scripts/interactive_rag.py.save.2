# ================= OLLAMA =================
def call_ollama(prompt: str) -> str:
    payload = {
        "model": OLLAMA_MODEL,
        "prompt": prompt,
        "stream": False,
        "options": {
            "temperature": 0.0,
            "num_predict": 1200
        }
    }

    r = requests.post(OLLAMA_URL, json=payload)
    if r.status_code != 200:
        return ""

    return r.n().get("response", "").strip()

